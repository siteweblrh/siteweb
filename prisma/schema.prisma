generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          Role      @default(USER)
  accounts      Account[]
  sessions      Session[]
  clubId        String?
  club          Club?     @relation(fields: [clubId], references: [id])
  articles      News[]    @relation("NewsAuthor")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum Role {
  ADMIN
  USER
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Club {
  id                String              @id @default(cuid())
  slug              String              @unique
  shortCode         String?             @unique
  name              String
  city              String
  kind              ClubKind            @default(STANDALONE)
  users             User[]
  news              News[]
  members           Member[]
  sponsors          Sponsor[]
  homeMatches       Match[]             @relation("HomeMatches")
  awayMatches       Match[]             @relation("AwayMatches")
  goals             Goal[]
  standings         Standing[]
  competitionEntries CompetitionEntry[]
  homeVenueGazonId  String?
  homeVenueGazon    Venue?              @relation("ClubGazonVenue", fields: [homeVenueGazonId], references: [id])
  homeVenueSalleId  String?
  homeVenueSalle    Venue?              @relation("ClubSalleVenue", fields: [homeVenueSalleId], references: [id])
  // Self-relation M:N : si ce Club est de type ENTENTE, parentClubs liste les
  // clubs constituants. Inversement, "ententes" liste les ententes dont ce
  // club fait partie. Les clubs STANDALONE ont parentClubs vide.
  parentClubs       Club[]              @relation("ClubEntenteMembers")
  ententes          Club[]              @relation("ClubEntenteMembers")
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([kind])
}

enum ClubKind {
  STANDALONE
  ENTENTE
}

model News {
  id          String       @id @default(cuid())
  slug        String       @unique
  title       String
  excerpt     String?
  content     String
  coverImage  String?
  category    NewsCategory @default(ACTUALITE)
  published   Boolean      @default(false)
  publishedAt DateTime?
  authorId    String
  author      User         @relation("NewsAuthor", fields: [authorId], references: [id])
  clubId      String?
  club        Club?        @relation(fields: [clubId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([published, publishedAt])
  @@index([clubId])
  @@index([category])
}

enum NewsCategory {
  ACTUALITE
  RESULTAT
  EVENEMENT
  COMMUNIQUE
}

model Member {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  license   String   @unique
  clubId    String
  club      Club     @relation(fields: [clubId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sponsor {
  id        String        @id @default(cuid())
  name      String
  logo      String?
  scope     SponsorScope  @default(CLUB)
  clubId    String?
  club      Club?         @relation(fields: [clubId], references: [id])
  matches   Match[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

enum SponsorScope {
  LIGUE
  CLUB
  EVENT
}

enum Mode {
  GAZON
  SALLE
}

enum MatchStatus {
  SCHEDULED
  LIVE
  HALFTIME
  FINISHED
  POSTPONED
  CANCELLED
}

model Competition {
  id        String              @id @default(cuid())
  slug      String              @unique
  name      String
  mode      Mode
  season    String
  category  String              @default("Sénior")
  matches   Match[]
  standings Standing[]
  entries   CompetitionEntry[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

// Inscription d'un club (ou d'une entente) à une compétition. Permet de
// déclarer la liste des participants avant que les matchs ne soient créés
// et borne le sélecteur du form match aux équipes effectivement inscrites.
model CompetitionEntry {
  id             String       @id @default(cuid())
  competitionId  String
  competition    Competition  @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  clubId         String
  club           Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  registeredAt   DateTime     @default(now())

  @@unique([competitionId, clubId])
  @@index([competitionId])
  @@index([clubId])
}

model Match {
  id            String         @id @default(cuid())
  competitionId String
  competition   Competition    @relation(fields: [competitionId], references: [id])
  homeClubId    String
  homeClub      Club           @relation("HomeMatches", fields: [homeClubId], references: [id])
  awayClubId    String
  awayClub      Club           @relation("AwayMatches", fields: [awayClubId], references: [id])
  homeScore     Int?
  awayScore     Int?
  kickoffAt     DateTime
  venue         String?
  venueId       String?
  venueRef      Venue?         @relation(fields: [venueId], references: [id])
  status        MatchStatus    @default(SCHEDULED)
  matchday      Int?
  sponsorId     String?
  sponsor       Sponsor?       @relation(fields: [sponsorId], references: [id])
  goals         Goal[]
  referees      MatchReferee[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([competitionId, kickoffAt])
  @@index([status, kickoffAt])
  @@index([homeClubId])
  @@index([awayClubId])
  @@index([venueId])
}

model Venue {
  id            String   @id @default(cuid())
  name          String
  city          String
  address       String?
  supportsGazon Boolean  @default(false)
  supportsSalle Boolean  @default(false)
  notes         String?
  gazonHomeFor  Club[]   @relation("ClubGazonVenue")
  salleHomeFor  Club[]   @relation("ClubSalleVenue")
  matches       Match[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([name])
}

model Referee {
  id        String         @id @default(cuid())
  fullName  String
  license   String?        @unique
  email     String?
  phone     String?
  notes     String?
  matches   MatchReferee[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([fullName])
}

enum RefereeRole {
  PRINCIPAL
  DELEGUE
}

model MatchReferee {
  matchId   String
  refereeId String
  role      RefereeRole @default(PRINCIPAL)
  match     Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  referee   Referee     @relation(fields: [refereeId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@id([matchId, refereeId])
  @@index([matchId])
  @@index([refereeId])
}

model Goal {
  id            String  @id @default(cuid())
  matchId       String
  match         Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  scoringClubId String
  scoringClub   Club    @relation(fields: [scoringClubId], references: [id])
  minute        Int
  scorerName    String?

  @@index([matchId])
}

model Standing {
  id            String      @id @default(cuid())
  competitionId String
  competition   Competition @relation(fields: [competitionId], references: [id])
  clubId        String
  club          Club        @relation(fields: [clubId], references: [id])
  rank          Int
  played        Int         @default(0)
  wins          Int         @default(0)
  draws         Int         @default(0)
  losses        Int         @default(0)
  goalsFor      Int         @default(0)
  goalsAgainst  Int         @default(0)
  points        Int         @default(0)
  updatedAt     DateTime    @updatedAt

  @@unique([competitionId, clubId])
  @@index([competitionId, rank])
}

model BureauMember {
  id        String    @id @default(cuid())
  fullName  String
  role      String
  order     Int       @default(0)
  photo     String?
  email     String?
  phone     String?
  bio       String?
  startedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([order])
}

model Commission {
  id          String             @id @default(cuid())
  slug        String             @unique
  name        String
  description String?
  mission     String?
  order       Int                @default(0)
  members     CommissionMember[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([order])
}

model CommissionMember {
  id           String     @id @default(cuid())
  fullName     String
  role         String
  order        Int        @default(0)
  photo        String?
  email        String?
  commissionId String
  commission   Commission @relation(fields: [commissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([commissionId, order])
}
