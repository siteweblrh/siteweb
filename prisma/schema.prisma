generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          Role      @default(USER)
  accounts      Account[]
  sessions      Session[]
  clubId        String?
  club          Club?     @relation(fields: [clubId], references: [id])
  articles      News[]    @relation("NewsAuthor")
  matchNotes    MatchNote[] @relation("MatchNoteAuthor")
  auditEntries  AuditLog[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Trace des actions admin destructives ou sensibles (suppressions, mises à
// jour de scores officiels, création batch de journée, etc.). Sert à la
// traçabilité en cas de contestation. La page admin /dashboard/ligue/audit
// permet de consulter l'historique.
model AuditLog {
  id        String   @id @default(cuid())
  // Auteur de l'action. Nullable car l'utilisateur peut être supprimé après ;
  // userEmail capture l'identité au moment de l'action.
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userEmail String?
  userName  String?
  // Verbe de l'action (DELETE_MATCH, UPDATE_SCORE, CREATE_MATCHDAY, etc.)
  action    String
  // Type d'entité visée (Match, Competition, Goal, Card, Injury, Club, etc.)
  entity    String
  // ID de l'entité visée (peut être null pour batch ops).
  entityId  String?
  // Contexte additionnel libre (résumé human-readable, valeurs avant/après…)
  metadata  Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
}

enum Role {
  ADMIN
  USER
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Club {
  id                String              @id @default(cuid())
  slug              String              @unique
  shortCode         String?             @unique
  name              String
  city              String
  kind              ClubKind            @default(STANDALONE)
  // Coordonnées et identité publique (éditables par le manager du club)
  email             String?
  phone             String?
  website           String?
  address           String?
  socials           Json?
  description       String?
  primaryColor      String?
  logo              String?
  foundedYear       Int?
  // Position carte (override prioritaire sur le lookup par ville). Si null,
  // fallback sur getCityCoords(city) dans lib/reunionCityCoords.ts.
  latitude          Float?
  longitude         Float?
  users             User[]
  news              News[]
  members           Member[]
  sponsors          Sponsor[]
  homeMatches       Match[]             @relation("HomeMatches")
  awayMatches       Match[]             @relation("AwayMatches")
  organizedMatches  Match[]             @relation("OrganizerOfMatches")
  goals             Goal[]
  matchCards        MatchCard[]         @relation("ClubMatchCards")
  matchInjuries     MatchInjury[]       @relation("ClubMatchInjuries")
  standings         Standing[]
  competitionEntries CompetitionEntry[]
  referees          Referee[]
  homeVenueGazonId  String?
  homeVenueGazon    Venue?              @relation("ClubGazonVenue", fields: [homeVenueGazonId], references: [id])
  homeVenueSalleId  String?
  homeVenueSalle    Venue?              @relation("ClubSalleVenue", fields: [homeVenueSalleId], references: [id])
  // Self-relation M:N : si ce Club est de type ENTENTE, parentClubs liste les
  // clubs constituants. Inversement, "ententes" liste les ententes dont ce
  // club fait partie. Les clubs STANDALONE ont parentClubs vide.
  parentClubs       Club[]              @relation("ClubEntenteMembers")
  ententes          Club[]              @relation("ClubEntenteMembers")
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([kind])
}

enum ClubKind {
  STANDALONE
  ENTENTE
}

model News {
  id          String       @id @default(cuid())
  slug        String       @unique
  title       String
  excerpt     String?
  content     String
  coverImage  String?
  category    NewsCategory @default(ACTUALITE)
  published   Boolean      @default(false)
  publishedAt DateTime?
  authorId    String
  author      User         @relation("NewsAuthor", fields: [authorId], references: [id])
  clubId      String?
  club        Club?        @relation(fields: [clubId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([published, publishedAt])
  @@index([clubId])
  @@index([category])
}

enum NewsCategory {
  ACTUALITE
  RESULTAT
  EVENEMENT
  COMMUNIQUE
}

model Member {
  id               String         @id @default(cuid())
  firstName        String
  lastName         String
  license          String         @unique
  kind             MemberKind     @default(PLAYER)
  position         String?
  jerseyNumber     Int?
  category         MemberCategory @default(SENIOR)
  photo            String?
  birthdate        DateTime?
  // Mis en avant sur la fiche publique du club (carte large "À la une").
  // Réservé aux PLAYER côté action — coachs/staff n'utilisent pas ce flag.
  isFeatured       Boolean        @default(false)
  featuredHeadline String?
  // Stats par compétition : saisie manuelle par le manager via /dashboard/team.
  // Le total agrégé (effectif club, podium buteurs cross-clubs) est dérivé par
  // somme à la lecture. Quand les feuilles de match arriveront, ces rangées
  // seront alimentées automatiquement à partir de Goal + lineup.
  competitionStats   MemberCompetitionStats[]
  playerOfMonthAwards PlayerOfMonth[]
  // Faits marquants liés à ce joueur (saisis sur la fiche match admin)
  goalsAsScorer    Goal[]         @relation("MemberGoals")
  matchCards       MatchCard[]    @relation("MemberMatchCards")
  injuries         MatchInjury[]  @relation("MemberInjuries")
  replacements     MatchInjury[]  @relation("MemberReplacements")
  clubId           String
  club             Club           @relation(fields: [clubId], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([clubId, kind])
  @@index([clubId, category])
  @@index([clubId, isFeatured])
}

// Stats saisies par compétition pour un membre. Permet de différencier les
// buteurs par tournoi (D1, Coupe de la Ligue, etc.) tout en restant compatible
// avec la future bascule vers les feuilles de match (lineup + buteurs).
model MemberCompetitionStats {
  id            String      @id @default(cuid())
  memberId      String
  member        Member      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  competitionId String
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  matchesPlayed Int         @default(0)
  goalsScored   Int         @default(0)
  updatedAt     DateTime    @updatedAt

  @@unique([memberId, competitionId])
  @@index([competitionId, goalsScored])
  @@index([memberId])
}

enum MemberKind {
  PLAYER
  COACH
  STAFF
}

enum MemberCategory {
  U11
  U14
  U17
  U19
  SENIOR
  VETERAN
}

model Sponsor {
  id        String        @id @default(cuid())
  name      String
  logo      String?
  scope     SponsorScope  @default(CLUB)
  clubId    String?
  club      Club?         @relation(fields: [clubId], references: [id])
  matches   Match[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

enum SponsorScope {
  LIGUE
  CLUB
  EVENT
}

enum Mode {
  GAZON
  SALLE
}

enum MatchStatus {
  SCHEDULED
  LIVE
  HALFTIME
  FINISHED
  POSTPONED
  CANCELLED
}

enum MatchPhase {
  REGULAR
  R32
  R16
  QUARTER
  SEMI
  THIRD_PLACE
  FINAL
}

model Competition {
  id           String                    @id @default(cuid())
  slug         String                    @unique
  name         String
  mode         Mode
  season       String
  category     String                    @default("Sénior")
  // Format détermine l'affichage public :
  //   CHAMPIONSHIP          : tableau classement uniquement (round-robin pur)
  //   CHAMPIONSHIP_PLAYOFFS : tableau + phase finale (matchs Match.phase != REGULAR)
  //   CUP                   : bracket uniquement, pas de classement
  format       CompetitionFormat         @default(CHAMPIONSHIP)
  matches      Match[]
  standings    Standing[]
  entries      CompetitionEntry[]
  memberStats  MemberCompetitionStats[]
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
}

enum CompetitionFormat {
  CHAMPIONSHIP
  CHAMPIONSHIP_PLAYOFFS
  CUP
}

// Inscription d'un club (ou d'une entente) à une compétition. Permet de
// déclarer la liste des participants avant que les matchs ne soient créés
// et borne le sélecteur du form match aux équipes effectivement inscrites.
model CompetitionEntry {
  id             String       @id @default(cuid())
  competitionId  String
  competition    Competition  @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  clubId         String
  club           Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  registeredAt   DateTime     @default(now())

  @@unique([competitionId, clubId])
  @@index([competitionId])
  @@index([clubId])
}

model Match {
  id            String         @id @default(cuid())
  competitionId String
  competition   Competition    @relation(fields: [competitionId], references: [id])
  homeClubId    String
  homeClub      Club           @relation("HomeMatches", fields: [homeClubId], references: [id])
  awayClubId    String
  awayClub      Club           @relation("AwayMatches", fields: [awayClubId], references: [id])
  homeScore     Int?
  awayScore     Int?
  kickoffAt     DateTime
  venue         String?
  venueId       String?
  venueRef      Venue?         @relation(fields: [venueId], references: [id])
  status        MatchStatus    @default(SCHEDULED)
  matchday      Int?
  // Phase de la compétition. REGULAR = phase régulière (pèse sur le
  // classement). Les autres valeurs (R32 → FINAL) marquent une phase
  // d'élimination directe et sont ignorées par updateStandings.
  phase         MatchPhase     @default(REGULAR)
  // Club responsable logistique de la journée (gymnase, table de marque, etc.).
  // Optionnel. Renseigné notamment via le workflow "Créer une journée".
  organizerClubId String?
  organizerClub   Club?        @relation("OrganizerOfMatches", fields: [organizerClubId], references: [id])
  sponsorId     String?
  sponsor       Sponsor?       @relation(fields: [sponsorId], references: [id])
  goals         Goal[]
  cards         MatchCard[]
  injuries      MatchInjury[]
  referees      MatchReferee[]
  notes         MatchNote[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([competitionId, kickoffAt])
  @@index([status, kickoffAt])
  @@index([homeClubId])
  @@index([awayClubId])
  @@index([venueId])
}

model MatchNote {
  id        String   @id @default(cuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("MatchNoteAuthor", fields: [authorId], references: [id])
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([matchId, createdAt])
  @@index([authorId])
}

model Venue {
  id            String   @id @default(cuid())
  name          String
  city          String
  address       String?
  supportsGazon Boolean  @default(false)
  supportsSalle Boolean  @default(false)
  notes         String?
  gazonHomeFor  Club[]   @relation("ClubGazonVenue")
  salleHomeFor  Club[]   @relation("ClubSalleVenue")
  matches       Match[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([name])
}

model Referee {
  id        String         @id @default(cuid())
  fullName  String
  license   String?        @unique
  email     String?
  phone     String?
  notes     String?
  // Niveau officiel (FFH). Trié par grade croissant pour faciliter
  // les vues groupées.
  level     RefereeLevel?
  // Photo (URL Cloudflare Images, via ImageUploader).
  photo     String?
  // Club d'affiliation (optionnel — un arbitre peut être indépendant).
  clubId    String?
  club      Club?          @relation(fields: [clubId], references: [id], onDelete: SetNull)
  matches   MatchReferee[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([fullName])
  @@index([level])
  @@index([clubId])
}

enum RefereeLevel {
  CANDIDAT
  JEUNE
  REGIONAL
  NATIONAL
}

enum RefereeRole {
  PRINCIPAL
  DELEGUE
}

model MatchReferee {
  matchId   String
  refereeId String
  role      RefereeRole @default(PRINCIPAL)
  match     Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  referee   Referee     @relation(fields: [refereeId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@id([matchId, refereeId])
  @@index([matchId])
  @@index([refereeId])
}

model Goal {
  id             String  @id @default(cuid())
  matchId        String
  match          Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  scoringClubId  String
  scoringClub    Club    @relation(fields: [scoringClubId], references: [id])
  minute         Int
  // Texte libre — utilisé en fallback si le buteur n'est pas dans le roster
  // (joueur non licencié, données historiques, etc.). Sinon scorerMember prime.
  scorerName     String?
  // Lien optionnel vers le buteur dans le roster. Permet d'alimenter à terme
  // MemberCompetitionStats.goalsScored automatiquement à partir des feuilles
  // de match au lieu de la saisie manuelle dans /dashboard/team.
  scorerMemberId String?
  scorerMember   Member? @relation("MemberGoals", fields: [scorerMemberId], references: [id])
  // Type de but : action ouverte, penalty corner, stroke, contre, etc. Libre
  // pour ne pas figer la nomenclature FIH dans le schéma.
  kind           String?
  createdAt      DateTime @default(now())

  @@index([matchId])
  @@index([scorerMemberId])
}

// Carton FIH attribué pendant un match. memberId optionnel — fallback memberName
// pour les cas où le joueur n'est pas dans le roster.
model MatchCard {
  id         String   @id @default(cuid())
  matchId    String
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  clubId     String
  club       Club     @relation("ClubMatchCards", fields: [clubId], references: [id])
  memberId   String?
  member     Member?  @relation("MemberMatchCards", fields: [memberId], references: [id])
  memberName String?
  minute     Int
  kind       CardKind
  reason     String?
  createdAt  DateTime @default(now())

  @@index([matchId])
  @@index([memberId])
}

enum CardKind {
  GREEN
  YELLOW
  RED
}

// Blessure constatée pendant un match. Sert au suivi médical et à la fiche
// faits-marquants publique. memberId optionnel comme MatchCard.
model MatchInjury {
  id                 String         @id @default(cuid())
  matchId            String
  match              Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  clubId             String
  club               Club           @relation("ClubMatchInjuries", fields: [clubId], references: [id])
  memberId           String?
  member             Member?        @relation("MemberInjuries", fields: [memberId], references: [id])
  memberName         String?
  minute             Int
  zone               String?
  severity           InjurySeverity @default(LIGHT)
  replacedByMemberId String?
  replacedByMember   Member?        @relation("MemberReplacements", fields: [replacedByMemberId], references: [id])
  notes              String?
  createdAt          DateTime       @default(now())

  @@index([matchId])
  @@index([memberId])
}

enum InjurySeverity {
  LIGHT
  MODERATE
  SERIOUS
}

model Standing {
  id            String      @id @default(cuid())
  competitionId String
  competition   Competition @relation(fields: [competitionId], references: [id])
  clubId        String
  club          Club        @relation(fields: [clubId], references: [id])
  rank          Int
  played        Int         @default(0)
  wins          Int         @default(0)
  draws         Int         @default(0)
  losses        Int         @default(0)
  goalsFor      Int         @default(0)
  goalsAgainst  Int         @default(0)
  points        Int         @default(0)
  updatedAt     DateTime    @updatedAt

  @@unique([competitionId, clubId])
  @@index([competitionId, rank])
}

model BureauMember {
  id        String    @id @default(cuid())
  fullName  String
  role      String
  order     Int       @default(0)
  photo     String?
  email     String?
  phone     String?
  bio       String?
  startedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([order])
}

model Commission {
  id          String             @id @default(cuid())
  slug        String             @unique
  name        String
  description String?
  mission     String?
  order       Int                @default(0)
  members     CommissionMember[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([order])
}

model CommissionMember {
  id           String     @id @default(cuid())
  fullName     String
  role         String
  order        Int        @default(0)
  photo        String?
  email        String?
  commissionId String
  commission   Commission @relation(fields: [commissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([commissionId, order])
}

// ─────────────────────────────────────────────────────────────────────────────
// SiteContent — textes éditoriaux éditables depuis le dashboard
// ─────────────────────────────────────────────────────────────────────────────
// Key/value simple. La clé est un slug technique (ex: "arbitrage.hero.subtitle"),
// la valeur est lue par les composants via `getContent(key)` avec fallback sur
// le DEFAULTS hard-codé (lib/siteContent.ts) si la rangée est absente.
//
// Catégorie + label sont purement pour l'admin (groupage et libellé humain).
//
// Si on supprime la rangée, le default reprend le dessus — utile pour
// "restaurer la valeur d'origine" depuis le dashboard.

// ─────────────────────────────────────────────────────────────────────────────
// PlayerOfMonth — joueur du mois mis en avant sur la page d'accueil
// ─────────────────────────────────────────────────────────────────────────────
// Un par mode (GAZON/SALLE) à la fois. La carte d'accueil lit la rangée la plus
// récente (effectiveAt desc) pour le mode courant. Saisie via /dashboard/ligue/
// joueur-du-mois. Si aucune rangée n'existe pour un mode, la card affiche un
// placeholder éditorial.

model PlayerOfMonth {
  id              String   @id @default(cuid())
  mode            Mode
  memberId        String
  member          Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  periodLabel     String
  effectiveAt     DateTime
  photo           String?
  goals           Int?
  assists         Int?
  extraStatLabel  String?
  extraStatValue  String?
  sponsor         String?
  quote           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([mode, effectiveAt])
  @@index([memberId])
}

model SiteContent {
  key       String   @id
  value     String
  category  String   @default("misc")
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@index([category])
}
